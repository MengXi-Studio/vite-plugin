{
	"name": "vite-plugin",
	"type": "module",
	"version": "0.0.4",
	"private": false,
	"description": "vite-plugin 是一个为 Vite 提供的插件",
	"packageManager": "pnpm@10.30.0",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev:core": "pnpm --filter @meng-xi/vite-plugin dev",
		"build:core": "pnpm --filter @meng-xi/vite-plugin build",
		"dev:docs": "pnpm --filter @meng-xi/vite-plugin-docs dev",
		"build:docs": "pnpm --filter @meng-xi/vite-plugin-docs build",
		"dev:playground": "pnpm --filter @meng-xi/vite-plugin-playground dev",
		"build:playground": "pnpm --filter @meng-xi/vite-plugin-playground build",
		"test": "pnpm --filter @meng-xi/vite-plugin-test test",
		"test:watch": "pnpm --filter @meng-xi/vite-plugin-test test:watch",
		"release": "bumpp",
		"lint": "eslint .",
		"lint:fix": "pnpm lint --fix",
		"clean": "rimraf --glob node_modules pnpm-lock.yaml packages/**/node_modules packages/**/pnpm-lock.yaml"
	},
	"devDependencies": {
		"@eslint/js": "^9.38.0",
		"bumpp": "^10.4.1",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.0",
		"eslint-plugin-prettier": "^5.5.0",
		"globals": "^16.2.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0"
	},
	"author": {
		"name": "PedroQue99",
		"email": "ksmengfang@163.com"
	},
	"license": "MIT",
	"homepage": "https://github.com/MengXi-Studio/vite-plugin#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MengXi-Studio/vite-plugin.git"
	},
	"bugs": "https://github.com/MengXi-Studio/vite-plugin/issues"
}
